# Copy this file to .env and fill in your values
# .env is gitignored — never commit real credentials

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pulsedata
POSTGRES_USER=pulsedata_user
POSTGRES_PASSWORD=your_secure_password_here

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@pulsedata.local
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here

# API Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8000

# Database Connection String (used by API)
# Format: Server=host;Database=db;User Id=user;Password=pass;Port=port;
# When running locally: Server=localhost;Database=pulsedata;User Id=pulsedata_user;Password=your_password;Port=5432;
# When running in Docker: Server=postgres;Database=pulsedata;User Id=pulsedata_user;Password=your_password;Port=5432;
ConnectionStrings__DefaultConnection=Server=localhost;Database=pulsedata;User Id=pulsedata_user;Password=your_secure_password_here;Port=5432;
